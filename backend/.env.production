NODE_ENV=production
PORT=10000

# Execution Settings - Optimized for free tier
EXECUTION_TIMEOUT=25000
MAX_OUTPUT_SIZE=5242880
MAX_MEMORY=256

# File Upload Settings
MAX_FILE_SIZE=10485760
UPLOAD_DIR=/tmp/uploads

# GitHub Integration
GITHUB_TOKEN=

# Logging
LOG_LEVEL=warn
LOG_RETENTION_DAYS=3

# Security
SANDBOX_ENABLED=true
