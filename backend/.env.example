NODE_ENV=development
PORT=5000

# Execution Settings
EXECUTION_TIMEOUT=30000
MAX_OUTPUT_SIZE=10485760
MAX_MEMORY=512

# File Upload Settings
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads

# GitHub Integration
GITHUB_TOKEN=your_github_token_here

# Logging
LOG_LEVEL=info
LOG_RETENTION_DAYS=7

# Security
SANDBOX_ENABLED=true
